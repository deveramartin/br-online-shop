# BR Online Shop Workspace Environment Variables Example

# ==========================================
# Backend API (apps/api-oos)
# ==========================================
ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__DefaultConnection=Data Source=app.db
Jwt__Issuer=https://localhost:5001
Jwt__Audience=br-online-shop
Jwt__SecretKey=your-dev-secret-key-min-256-bits-long-for-hmac-sha256
Jwt__ExpirationInMinutes=60

SentraCX__ApiUrl=http://localhost:5005
AiAnalytics__ApiUrl=http://localhost:4005

# ==========================================
# Web Shop Frontend (apps/web-shop)
# ==========================================
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_CRM_API_URL=http://localhost:5005
AUTH_SECRET=your-next-auth-secret-key-min-32-chars
AUTH_URL=https://localhost:3004
AUTH_HRMS_CLIENT_ID=web-shop-client
AUTH_HRMS_CLIENT_SECRET=web-shop-secret
AUTH_ISSUER=https://localhost:5001/
