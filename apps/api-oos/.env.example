# API OOS Environment Variables Example

# ASP.NET Core Environment
ASPNETCORE_ENVIRONMENT=Development

# Database Connection String (SQLite)
ConnectionStrings__DefaultConnection=Data Source=app.db

# JWT Configuration
Jwt__Issuer=https://localhost:5001
Jwt__Audience=br-online-shop
Jwt__SecretKey=your-dev-secret-key-min-256-bits-long-for-hmac-sha256
Jwt__ExpirationInMinutes=60

# External Service Endpoints
SentraCX__ApiUrl=http://localhost:5005
AiAnalytics__ApiUrl=http://localhost:4005

# CORS & Allowed Hosts
AllowedOrigins__0=http://localhost:3000
AllowedOrigins__1=http://localhost:3004
AllowedOrigins__2=https://localhost:3004
AllowedOrigins__3=http://localhost:3005
AllowedOrigins__4=http://localhost:3012
AllowedOrigins__5=http://localhost:5005
AllowedHosts=*
